// VivAudit database schema
// Source of truth for DB structure and generated Prisma Client types.
// See .kiro/specs/vivaudit/design.md §3 for the ERD.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Plan {
  FREE_TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum DocumentType {
  POLICIES
  IT_INFRASTRUCTURE
  PATIENT_DATA_HANDLING
  ADMIN_DOCS
}

enum AuditType {
  FULL
  FOCUSED
  QUICK_CHECK
}

enum AuditStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

// ─────────────────────────── Core models ───────────────────────────

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  passwordHash     String?    @map("password_hash")
  name             String?
  companyName      String?    @map("company_name")
  plan             Plan       @default(FREE_TRIAL)
  stripeCustomerId String?    @unique @map("stripe_customer_id")
  freeAuditUsed    Boolean    @default(false) @map("free_audit_used")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  workspaces Workspace[]
  payments   Payment[]
  accounts   Account[]
  sessions   Session[]

  @@map("users")
}

model Workspace {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  companyName     String   @map("company_name")
  industry        String?
  employeeCount   Int?     @map("employee_count")
  complianceNotes String?  @map("compliance_notes")
  createdAt       DateTime @default(now()) @map("created_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  audits    Audit[]
  documents Document[]
  history   AuditHistory[]

  @@index([userId])
  @@map("workspaces")
}

model Document {
  id           String       @id @default(uuid())
  workspaceId  String       @map("workspace_id")
  auditId      String?      @map("audit_id")
  fileName     String       @map("file_name")
  fileUrl      String       @map("file_url")
  storageKey   String       @map("storage_key")
  documentType DocumentType @map("document_type")
  sizeBytes    Int          @map("size_bytes")
  uploadDate   DateTime     @default(now()) @map("upload_date")
  deletedAt    DateTime?    @map("deleted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  audit     Audit?    @relation(fields: [auditId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([auditId])
  @@map("documents")
}

model Audit {
  id              String      @id @default(uuid())
  workspaceId     String      @map("workspace_id")
  auditType       AuditType   @default(FULL) @map("audit_type")
  status          AuditStatus @default(PENDING)
  complianceScore Int?        @map("compliance_score")
  errorReason     String?     @map("error_reason")
  createdAt       DateTime    @default(now()) @map("created_at")
  completedAt     DateTime?   @map("completed_at")

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents Document[]
  report    ComplianceReport?
  history   AuditHistory[]

  @@index([workspaceId])
  @@map("audits")
}

model ComplianceReport {
  id               String   @id @default(uuid())
  auditId          String   @unique @map("audit_id")
  riskScore        Int      @map("risk_score")
  findings         Json
  recommendations  Json
  remediationSteps Json     @map("remediation_steps")
  pdfUrl           String?  @map("pdf_url")
  createdAt        DateTime @default(now()) @map("created_at")

  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@map("compliance_reports")
}

model Payment {
  id                   String        @id @default(uuid())
  userId               String        @map("user_id")
  stripeCustomerId     String        @map("stripe_customer_id")
  stripeSubscriptionId String?       @map("stripe_subscription_id")
  plan                 Plan
  status               PaymentStatus
  renewalDate          DateTime?     @map("renewal_date")
  createdAt            DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payments")
}

model AuditHistory {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  auditId     String   @map("audit_id")
  score       Int
  passedItems Int      @map("passed_items")
  failedItems Int      @map("failed_items")
  auditDate   DateTime @default(now()) @map("audit_date")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  audit     Audit     @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("audit_history")
}

// Idempotency log for Stripe webhooks (see requirements R7.5)
model ProcessedWebhookEvent {
  id          String   @id // Stripe event id
  type        String
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("processed_webhook_events")
}

// ─────────────────────────── NextAuth tables ───────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

# ─────────────────────────────────────────────────────────────
# VivAudit environment variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# App
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Database (Supabase Postgres)
DATABASE_URL="postgresql://user:password@host:5432/vivaudit?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/vivaudit?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic Claude
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-20240620"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PROFESSIONAL=""

# Object storage  (provider = "s3" | "supabase")
STORAGE_PROVIDER="s3"
STORAGE_BUCKET="vivaudit-documents"
# AWS S3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Supabase storage (if STORAGE_PROVIDER=supabase)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Email  (provider = "resend" | "sendgrid")
EMAIL_PROVIDER="resend"
EMAIL_FROM="VivAudit <noreply@vivavault.shop>"
RESEND_API_KEY=""
SENDGRID_API_KEY=""

# Observability
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Internal job runner auth (shared secret to call /api/internal/*)
INTERNAL_JOB_SECRET="generate-with: openssl rand -hex 32"
